# Compose project and host binding
COMPOSE_PROJECT_NAME=artifact-hub
BIND_ADDRESS=127.0.0.1
PORT=8080

# The public origin shown in stable artifact URLs. Do not add a trailing slash.
PUBLIC_URL=https://artifacts.example.com

# Keep these four values in sync. Use a long URL-safe password.
POSTGRES_DB=artifact_hub
POSTGRES_USER=artifact
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgres://artifact:replace-with-a-long-random-password@postgres:5432/artifact_hub?sslmode=disable
